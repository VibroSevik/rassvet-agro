<!-- PRELOADER START -->
<style>
    /* Стили для перекрытия всего экрана */
    #page-preloader {
        position: fixed;
        left: 0;
        top: 0;
        right: 0;
        bottom: 0;
        background: #ffffff; /* Белый фон, перекрывающий сайт */
        z-index: 100500; /* Очень высокий слой, чтобы быть поверх всего */
        display: flex;
        justify-content: center;
        align-items: center;
        transition: opacity 0.5s ease-out, visibility 0.5s;
    }

    /* Когда добавляем класс .done, прелоадер исчезает */
    #page-preloader.done {
        opacity: 0;
        visibility: hidden;
    }

    /* Контейнер анимации */
    .loader-wrapper {
        position: relative;
        width: 150px;
        height: 150px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* Логотип */
    .loader-logo {
        width: 90px;
        height: auto;
        position: relative;
        z-index: 2;
        animation: agro-pulse 2s infinite ease-in-out;
    }

    /* Вращающееся кольцо */
    .loader-ring {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 4px solid rgba(0, 0, 0, 0.05);
        border-top-color: #2c3e50; /* Основной цвет */
        animation: agro-spin 1s linear infinite;
    }

    /* Внутреннее кольцо */
    .loader-ring-inner {
        position: absolute;
        top: 15px;
        left: 15px;
        right: 15px;
        bottom: 15px;
        border-radius: 50%;
        border: 2px solid transparent;
        border-bottom-color: #27ae60; /* Зеленый акцент */
        animation: agro-spin-reverse 1.5s linear infinite;
    }

    /* Анимации */
    @keyframes agro-spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    @keyframes agro-spin-reverse {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(-360deg); }
    }
    @keyframes agro-pulse {
        0% { transform: scale(0.95); opacity: 0.9; }
        50% { transform: scale(1.05); opacity: 1; }
        100% { transform: scale(0.95); opacity: 0.9; }
    }
</style>

<div id="page-preloader">
    <div class="loader-wrapper">
        <div class="loader-ring"></div>
        <div class="loader-ring-inner"></div>
        <!-- Путь к картинке. Убедитесь, что файл загружен в image/catalog/ -->
        <img src="image/catalog/logo_agrofirmarassvet.png" class="loader-logo" alt="Загрузка...">
    </div>
</div>

<script>
    // Скрипт скрытия прелоадера после полной загрузки страницы
    window.addEventListener('load', function() {
        var preloader = document.getElementById('page-preloader');
        // Небольшая задержка (200мс) для плавности, чтобы не мигало, если сайт загрузился мгновенно
        setTimeout(function() {
            if(preloader) {
                preloader.classList.add('done');
            }
        }, 200);
    });
</script>
<!-- PRELOADER END -->
            
<nav id="top">
  <div class="container">{{ currency }}
    {{ language }}
    <div id="top-links" class="nav pull-right">
      <ul class="list-inline">
        <li><a href="{{ contact }}"><i class="fa fa-phone"></i></a> <span class="hidden-xs hidden-sm hidden-md">{{ telephone }}</span></li>
        <li class="dropdown"><a href="{{ account }}" title="{{ text_account }}" class="dropdown-toggle" data-toggle="dropdown"><i class="fa fa-user"></i> <span class="hidden-xs hidden-sm hidden-md">{{ text_account }}</span> <span class="caret"></span></a>
          <ul class="dropdown-menu dropdown-menu-right">
            {% if logged %}
            <li><a href="{{ account }}">{{ text_account }}</a></li>
            <li><a href="{{ order }}">{{ text_order }}</a></li>
            <li><a href="{{ transaction }}">{{ text_transaction }}</a></li>
            <li><a href="{{ download }}">{{ text_download }}</a></li>
            <li><a href="{{ logout }}">{{ text_logout }}</a></li>
            {% else %}
            <li><a href="{{ register }}">{{ text_register }}</a></li>
            <li><a href="{{ login }}">{{ text_login }}</a></li>
            {% endif %}
          </ul>
        </li>
        <li><a href="{{ wishlist }}" id="wishlist-total" title="{{ text_wishlist }}"><i class="fa fa-heart"></i> <span class="hidden-xs hidden-sm hidden-md">{{ text_wishlist }}</span></a></li>
        <li><a href="{{ shopping_cart }}" title="{{ text_shopping_cart }}"><i class="fa fa-shopping-cart"></i> <span class="hidden-xs hidden-sm hidden-md">{{ text_shopping_cart }}</span></a></li>
        <li><a href="{{ checkout }}" title="{{ text_checkout }}"><i class="fa fa-share"></i> <span class="hidden-xs hidden-sm hidden-md">{{ text_checkout }}</span></a></li>
      </ul>
    </div>
  </div>
</nav>
